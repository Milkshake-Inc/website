---
interface Props {
  title: string;
  slug: string;
  type: string;
}

const { title, slug, type } = Astro.props;
---
<a href={`/blog/${slug}`} class="group flex items-center gap-3 py-3 border-b border-gray-100 last:border-0 hover:bg-gray-50 -mx-2 px-2 rounded transition-colors">
  <span class="px-2 py-0.5 text-xs bg-gray-200 rounded text-black flex-shrink-0">{type}</span>
  <span class="text-gray-900 group-hover:underline font-medium">{title}</span>
</a>
