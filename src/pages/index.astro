---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import BlogCard from '../components/BlogCard.astro';

const works = [
  {
    title: 'GolfParty.io',
    slug: 'golfparty',
    image: '/images/work/golfparty.png',
    status: 'live' as const,
    description: 'A fast-paced multiplayer golf game hosted on Poki where players compete in real-time matches.',
  },
  {
    title: 'Crops And Robbers',
    slug: 'crops-and-robbers',
    image: '/images/work/cropsandrobbers.png',
    status: 'wip' as const,
    description: 'An innovative multiplayer farming game in development that pits farmers against robbers in an exciting strategic battle.',
  },
  {
    title: 'Burgaagh!',
    slug: 'burgaagh',
    image: '/images/work/burgaagh.png',
    status: 'wip' as const,
    description: 'A delightful casual burger stacking game in development where players stack burgers with precision and style.',
  },
];

const posts = [
  { title: 'Lightmapping in ThreeJS', slug: 'lightmapping-threejs', type: 'gfx' },
  { title: 'Pre-DepthPass based transparency', slug: 'pre-depthpass-transparency', type: 'gfx' },
  { title: 'Creating Weapon Shaders', slug: 'weapon-shader', type: 'gfx' },
];
---
<BaseLayout>
  <Header />

  <section class="flex items-center justify-center py-24 px-6 border-b border-gray-200">
    <img src="/icons/milkshakelogo.png" alt="milkshake.io" width="400" height="200" style="width: auto; height: auto; max-width: 400px;" />
  </section>

  <section id="work" class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-black text-gray-900 mb-8">
        <a href="#work" class="hover:underline">Work</a>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {works.map(work => <WorkCard {...work} />)}
      </div>
    </div>
  </section>

  <section id="blog" class="py-16 px-6 border-t border-gray-200">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-black text-gray-900 mb-8">
        <a href="#blog" class="hover:underline">Blog</a>
      </h2>
      <div>
        {posts.map(post => <BlogCard {...post} />)}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
