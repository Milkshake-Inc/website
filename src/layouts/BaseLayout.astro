---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'milkshake.io' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/icons/favi.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-gray-900 antialiased min-h-screen flex flex-col">
    <slot />
  </body>
</html>
